# 개발자 로컬 설정 예시 — 복사해서 `.env` 로 저장한다(`.env` 는 gitignore).
#   cp .env.example .env

# 목(MSW) 사용 여부. enabled 면 BE 없이 전 플로우가 목으로 돈다. 실 BE 붙일 땐 disabled.
VITE_API_MOCKING=enabled

# API 호출 base — 로컬 BE 게이트웨이 직접 호출.
VITE_API_BASE_URL=http://localhost:8000

# Toss 공개 테스트 클라이언트 키.
VITE_TOSS_CLIENT_KEY=test_ck_LkKEypNArW9zAeZ9avLX3lmeaxYG
